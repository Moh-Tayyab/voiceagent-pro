# VoiceAgent Pro Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# API Keys (Required)
# ============================================

# Anthropic - Claude API
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - Agents SDK and fallbacks
OPENAI_API_KEY=sk-...

# Twilio - Telephony
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Deepgram - Speech-to-Text
DEEPGRAM_API_KEY=your_deepgram_key

# ElevenLabs - Text-to-Speech
ELEVENLABS_API_KEY=your_elevenlabs_key

# ============================================
# MCP Server Configuration
# ============================================

# MCP Server Ports (development)
KNOWLEDGE_MCP_PORT=8001
CRM_MCP_PORT=8002
TICKETING_MCP_PORT=8003
CALENDAR_MCP_PORT=8004
ANALYTICS_MCP_PORT=8005
ESCALATION_MCP_PORT=8006

# ============================================
# External Service Keys (per client)
# ============================================

# CRM Integration (HubSpot/Salesforce)
CRM_API_KEY=your_crm_api_key

# Ticketing (Zendesk)
ZENDESK_API_KEY=your_zendesk_key
ZENDESK_SUBDOMAIN=your_subdomain

# Calendar (Google)
GOOGLE_API_KEY=your_google_key

# PagerDuty (Escalation)
PAGERDUTY_API_KEY=your_pagerduty_key

# ============================================
# Database Configuration
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voiceagent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=voiceagent

# Redis
REDIS_URL=redis://localhost:6379

# ============================================
# Application Settings
# ============================================

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
API_ENV=development

# Internal API key for service-to-service auth
INTERNAL_API_KEY=your_internal_api_key

# ============================================
# Voice Settings
# ============================================

# Default voice for TTS
DEFAULT_VOICE=Rachel

# STT Language default
DEFAULT_LANGUAGE=en

# Max response words (TTS constraint)
MAX_RESPONSE_WORDS=150

# ============================================
# Rate Limiting
# ============================================

# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Logging
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO